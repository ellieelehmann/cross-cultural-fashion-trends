__pycache__/
*.pyc
.venv/
.env
.env.local
.DS_Store
.ipynb_checkpoints/

# Raw pulls can be large or contain fresh scrapes; treat as ephemeral.
data/raw/*
!data/raw/.gitkeep

# Processed artifacts are rebuilt by the pipeline.
data/processed/*
!data/processed/.gitkeep

# Sample data is deterministic and small; keep it checked in.
!data/sample/*.csv
